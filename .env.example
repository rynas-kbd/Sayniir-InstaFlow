# =============================================
# Supabase
# =============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================
# Meta / Facebook App
# =============================================

# Instagram et Messenger peuvent utiliser deux apps Meta distinctes.
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=
META_MESSENGER_APP_ID=
META_MESSENGER_APP_SECRET=

# WhatsApp Embedded Signup (OAuth par popup, pas un redirect classique).
# Nécessite d'avoir créé une Configuration WhatsApp dans le Meta App Dashboard
# (WhatsApp > Configuration) pour obtenir META_WHATSAPP_CONFIG_ID.
NEXT_PUBLIC_META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_CONFIG_ID=

# Utilisée pour la vérification de signature des webhooks WhatsApp.
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# Secret token you choose freely (e.g. "my_webhook_secret_2024")
META_WEBHOOK_VERIFY_TOKEN=
META_MESSENGER_VERIFY_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=my_webhook_secret_2024

# =============================================
# App
# =============================================
NEXT_PUBLIC_APP_URL=

# Clé secrète pour appeler les crons depuis Vercel
CRON_SECRET=

# =============================================
# AI providers
# =============================================
GEMINI_API_KEY=

# =============================================
# Encryption (tokens & AI keys at rest)
# =============================================
SETTINGS_ENCRYPTION_KEY=




